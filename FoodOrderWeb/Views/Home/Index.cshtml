@model IEnumerable<FoodOrderWeb.Models.FoodItem>

@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as List<FoodOrderWeb.Models.Category>;
    var newItems = ViewBag.NewItems as List<FoodOrderWeb.Models.FoodItem>;
}

<!-- Hero Section -->
<section class="hero-section bg-gradient-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center min-vh-50">
            <div class="col-lg-6 animate__animated animate__fadeInLeft">
                <h1 class="display-3 fw-bold mb-4">
                    Đồ ăn ngon - <br>Giao tận nơi
                </h1>
                <p class="lead mb-4 fs-4">
                    Hàng ngàn món ăn hấp dẫn đang chờ bạn.
                    Đăng ký ngay để nhận ưu đãi đặc biệt lên đến 50%!
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register"
                           class="btn btn-light btn-lg px-5 py-3 shadow-sm">
                            <i class="fas fa-user-plus me-2"></i>Đăng ký ngay
                        </a>
                    }
                    <a asp-controller="Menu" asp-action="Index"
                       class="btn btn-outline-light btn-lg px-5 py-3">
                        <i class="fas fa-utensils me-2"></i>Xem thực đơn
                    </a>
                </div>

                <!-- Thống kê nhanh -->
                <div class="row mt-5 g-4">
                    <div class="col-4">
                        <div class="stat-item">
                            <h3 class="fw-bold mb-0">500+</h3>
                            <small class="opacity-75">Món ăn</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-item">
                            <h3 class="fw-bold mb-0">10k+</h3>
                            <small class="opacity-75">Khách hàng</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-item">
                            <h3 class="fw-bold mb-0">30'</h3>
                            <small class="opacity-75">Giao hàng</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 text-center animate__animated animate__fadeInRight">
                <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?ixlib=rb-4.0.3&auto=format&fit=crop&w=1080&q=80"
                     alt="Food Delivery" class="img-fluid rounded-4 shadow-lg hero-image"
                     style="max-height: 500px; object-fit: cover;">
            </div>
        </div>
    </div>
</section>

<!-- Search Section -->
<section class="search-section py-5 bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="search-box bg-white p-4 rounded-4 shadow">
                    <h4 class="text-center mb-4">Bạn muốn ăn gì hôm nay?</h4>
                    <form asp-controller="Menu" asp-action="Index" method="get" class="d-flex">
                        <input type="text" name="searchString" class="form-control form-control-lg me-2"
                               placeholder="Tìm món ăn, danh mục..." id="searchInput">
                        <button type="submit" class="btn btn-primary btn-lg px-4">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                    <!-- Search suggestions -->
                    <div id="searchSuggestions" class="suggestions-box mt-2"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="categories-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Danh mục món ăn</h2>
            <p class="text-muted">Khám phá đa dạng các món ăn theo sở thích</p>
        </div>

        <div class="row g-4">
            @foreach (var category in categories.Take(8))
            {
                <div class="col-lg-3 col-md-4 col-6">
                    <a asp-controller="Menu" asp-action="Index" asp-route-categoryId="@category.Id"
                       class="text-decoration-none">
                        <div class="card category-card h-100 border-0 shadow-sm hover-scale">
                            <div class="card-body text-center py-4">
                                <div class="category-icon mb-3">
                                    @switch (category.Id % 4)
                                    {
                                        case 0:
                                            <i class="fas fa-egg fa-3x text-primary"></i>
                                            break;
                                        case 1:
                                            <i class="fas fa-utensils fa-3x text-success"></i>
                                            break;
                                        case 2:
                                            <i class="fas fa-coffee fa-3x text-warning"></i>
                                            break;
                                        case 3:
                                            <i class="fas fa-ice-cream fa-3x text-info"></i>
                                            break;
                                    }
                                </div>
                                <h5 class="card-title fw-bold text-dark">@category.Name</h5>
                                <p class="card-text text-muted small">@(category.FoodItems?.Count ?? 0) món</p>
                                <span class="btn btn-outline-primary btn-sm">Khám phá →</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- Featured Items -->
<section class="featured-items py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Món ăn nổi bật</h2>
            <p class="text-muted">Những món ăn được yêu thích nhất</p>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card food-card h-100 border-0 shadow-sm hover-scale">
                        <div class="position-relative overflow-hidden">
                            <img src="@(item.ImageUrl ?? "https://images.unsplash.com/photo-1546069901-ba9596a5e864?ixlib=rb-4.0.3&auto=format&fit=crop&w=1160&q=80")"
                                 class="card-img-top" alt="@item.Name"
                                 style="height: 200px; object-fit: cover; transition: transform 0.3s;">
                            @if (!item.IsAvailable)
                            {
                                <span class="position-absolute top-0 end-0 bg-danger text-white px-3 py-1 m-2 rounded-pill small">
                                    Hết hàng
                                </span>
                            }
                            else
                            {
                                <span class="position-absolute top-0 start-0 bg-success text-white px-3 py-1 m-2 rounded-pill small">
                                    Còn hàng
                                </span>
                            }
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">@item.Name</h5>
                                <span class="badge bg-primary">@item.Category?.Name</span>
                            </div>
                            <p class="card-text text-muted small mb-3">
                                @(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-primary fw-bold fs-5">@item.Price.ToString("#,0")đ</span>
                                <div>
                                    <a asp-controller="Menu" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary btn-sm me-1">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin") && item.IsAvailable)
                                    {
                                        <button onclick="addToCart(@item.Id)"
                                                class="btn btn-primary btn-sm">
                                            <i class="fas fa-cart-plus"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Menu" asp-action="Index" class="btn btn-primary btn-lg px-5">
                Xem tất cả món ăn <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>
    </div>
</section>

<!-- New Items -->
@if (newItems != null && newItems.Any())
{
    <section class="new-items py-5">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="display-5 fw-bold">Món mới nhất</h2>
                <p class="text-muted">Cập nhật những món ăn mới mỗi ngày</p>
            </div>

            <div class="row g-4">
                @foreach (var item in newItems)
                {
                    <div class="col-md-3 col-6">
                        <div class="card food-card h-100 border-0 shadow-sm">
                            <img src="@(item.ImageUrl ?? "https://images.unsplash.com/photo-1546069901-ba9596a5e864?ixlib=rb-4.0.3&auto=format&fit=crop&w=1160&q=80")"
                                 class="card-img-top" alt="@item.Name"
                                 style="height: 150px; object-fit: cover;">
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold mb-1">@item.Name</h6>
                                <p class="text-primary fw-bold mb-2">@item.Price.ToString("#,0")đ</p>
                                <a asp-controller="Menu" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm w-100">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

