@section Scripts {
    <script>
        $(document).ready(function() {
            // Tìm kiếm gợi ý
            $('#searchInput').on('input', function() {
                var term = $(this).val();
                if (term.length < 2) {
                    $('#searchSuggestions').empty();
                    return;
                }

                $.get('/Menu/GetSuggestions', { term: term })
                    .done(function(data) {
                        var html = '';
                        if (data.length > 0) {
                            html = '<div class="list-group">';
                            data.forEach(function(item) {
                                html += `<a href="/Menu/Details/${item.id}" class="list-group-item list-group-item-action d-flex align-items-center">
                                            <img src="${item.image}" width="40" height="40" class="rounded me-2" onerror="this.src='/images/default-food.jpg'">
                                            <div>
                                                <strong>${item.name}</strong><br>
                                                <small class="text-primary">${item.price}</small>
                                            </div>
                                        </a>`;
                            });
                            html += '</div>';
                        }
                        $('#searchSuggestions').html(html);
                    });
            });

            // Đóng suggestions khi click ra ngoài
            $(document).on('click', function(e) {
                if (!$(e.target).closest('#searchInput, #searchSuggestions').length) {
                    $('#searchSuggestions').empty();
                }
            });
        });

        function addToCart(foodItemId) {
            $.post('/Cart/AddToCart', { foodItemId: foodItemId, quantity: 1 })
                .done(function(response) {
                    if (response.success) {
                        $('#cartCount').text(response.cartCount).show();
                        showToast('Đã thêm vào giỏ hàng!', 'success');
                    } else {
                        showToast(response.message, 'error');
                    }
                })
                .fail(function() {
                    showToast('Có lỗi xảy ra!', 'error');
                });
        }
    </script>
}

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .min-vh-50 {
        min-height: 50vh;
    }

    .hover-scale {
        transition: transform 0.3s;
    }

        .hover-scale:hover {
            transform: translateY(-10px);
        }

    .food-card:hover img {
        transform: scale(1.1);
    }

    .category-icon {
        transition: transform 0.3s;
    }

    .category-card:hover .category-icon {
        transform: scale(1.2);
    }

    .suggestions-box {
        position: absolute;
        z-index: 1000;
        width: 100%;
        max-width: 600px;
    }
</style>