@model IEnumerable<FoodOrderWeb.Models.FoodItem>

@{
    ViewData["Title"] = "Thực đơn";
    var categories = ViewBag.Categories as List<FoodOrderWeb.Models.Category>;
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var searchString = ViewBag.SearchString as string;
}

<!-- Breadcrumb -->
<section class="bg-light py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active">Thực đơn</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Header -->
<section class="py-4">
    <div class="container">
        <h1 class="display-5 fw-bold mb-2">Thực đơn</h1>
        <p class="text-muted">Khám phá đa dạng các món ăn hấp dẫn</p>
    </div>
</section>

<!-- Search Bar -->
<section class="pb-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <form asp-action="Index" method="get" class="d-flex">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0"
                               placeholder="Tìm món ăn..." value="@searchString">
                        <button type="submit" class="btn btn-primary px-4">Tìm</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section class="pb-4">
    <div class="container">
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <a asp-action="Index"
               class="btn @(selectedCategory == null ? "btn-primary" : "btn-outline-primary") rounded-pill px-4">
                Tất cả
            </a>
            @foreach (var category in categories)
            {
                <a asp-action="Index" asp-route-categoryId="@category.Id"
                   class="btn @(selectedCategory == category.Id ? "btn-primary" : "btn-outline-primary") rounded-pill px-4">
                    @category.Name
                </a>
            }
        </div>
    </div>
</section>

<!-- Results Count -->
<section class="pb-3">
    <div class="container">
        <p class="text-muted mb-0">
            <i class="fas fa-utensils me-2"></i>
            Tìm thấy <strong class="text-primary">@Model.Count()</strong> món ăn
        </p>
    </div>
</section>

<!-- Food Grid -->
<section class="pb-5">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <img src="https://cdn-icons-png.flaticon.com/512/4076/4076478.png"
                     alt="No food" width="150" class="mb-4 opacity-50">
                <h4 class="text-muted">Không tìm thấy món ăn nào</h4>
                <p class="text-muted mb-4">Hãy thử tìm kiếm với từ khóa khác</p>
                <a asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-redo me-2"></i>Xem tất cả
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card food-card h-100 border-0 shadow-sm">
                            <div class="row g-0">
                                <div class="col-4">
                                    <img src="@(item.ImageUrl ?? "https://images.unsplash.com/photo-1546069901-ba9596a5e864?w=400")"
                                         class="img-fluid rounded-start h-100" alt="@item.Name"
                                         style="object-fit: cover; min-height: 150px;">
                                </div>
                                <div class="col-8">
                                    <div class="card-body">
                                        <h5 class="card-title fw-bold mb-1">@item.Name</h5>
                                        <p class="card-text text-muted small mb-2">
                                            @(item.Description?.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)
                                        </p>
                                        <p class="card-text">
                                            <span class="fw-bold text-primary fs-5">@item.Price.ToString("#,0")đ</span>
                                        </p>
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<style>
    .food-card {
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
    }

        .food-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
        }

        .food-card .col-4 {
            overflow: hidden;
        }

        .food-card img {
            transition: transform 0.5s;
        }

        .food-card:hover img {
            transform: scale(1.1);
        }

    @@media (max-width: 768px) {
        .btn {
            font-size: 0.9rem;
            padding: 0.4rem 1rem;
        }
    }
</style>