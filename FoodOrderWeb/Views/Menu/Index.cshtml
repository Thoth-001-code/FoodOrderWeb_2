@model IEnumerable<FoodOrderWeb.Models.FoodItem>

@{
    ViewData["Title"] = "Thực đơn";
    var categories = ViewBag.Categories as List<FoodOrderWeb.Models.Category>;
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var searchString = ViewBag.SearchString as string;
}

<div class="container mt-4">
    <h1 class="mb-4">Thực đơn</h1>

    <!-- Thanh tìm kiếm và bộ lọc -->
    <div class="row mb-4">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="d-flex">
                <input type="text" name="searchString" class="form-control me-2"
                       placeholder="Tìm kiếm món ăn..." value="@searchString">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                </button>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <span class="text-muted">Tìm thấy @Model.Count() món ăn</span>
        </div>
    </div>

    <!-- Bộ lọc danh mục -->
    <div class="mb-4">
        <div class="btn-group flex-wrap" role="group">
            <a asp-action="Index" asp-route-categoryId="" asp-route-searchString="@searchString"
               class="btn @(selectedCategory == null ? "btn-primary" : "btn-outline-primary") mb-2">
                Tất cả
            </a>
            @foreach (var category in categories)
            {
                <a asp-action="Index" asp-route-categoryId="@category.Id" asp-route-searchString="@searchString"
                   class="btn @(selectedCategory == category.Id ? "btn-primary" : "btn-outline-primary") mb-2">
                    @category.Name
                </a>
            }
        </div>
    </div>

    <!-- Danh sách món ăn -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-search fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Không tìm thấy món ăn nào</h4>
            <p class="mb-3">Vui lòng thử lại với từ khóa khác</p>
            <a asp-action="Index" class="btn btn-primary">
                <i class="fas fa-redo me-2"></i>Xem tất cả
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm hover-card">
                        <div class="position-relative">
                            <img src="@(item.ImageUrl ?? "https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?ixlib=rb-1.2.1&auto=format&fit=crop&w=300&q=80")"
                                 class="card-img-top" alt="@item.Name"
                                 style="height: 200px; object-fit: cover;">
                            @if (!item.IsAvailable)
                            {
                                <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex align-items-center justify-content-center">
                                    <span class="badge bg-danger fs-6">Hết hàng</span>
                                </div>
                            }
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@item.Name</h5>
                                <span class="badge bg-primary">@item.Category?.Name</span>
                            </div>
                            <p class="card-text text-muted small">
                                @(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="h5 text-primary mb-0">@item.Price.ToString("#,0")đ</span>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-outline-primary">
                                    <i class="fas fa-eye me-1"></i>Chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2) !important;
        }

    .btn-group {
        gap: 5px;
    }
</style>