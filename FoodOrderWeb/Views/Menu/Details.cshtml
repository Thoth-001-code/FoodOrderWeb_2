@model FoodOrderWeb.Models.FoodItem

@{
    ViewData["Title"] = Model.Name;
    var relatedItems = ViewBag.RelatedItems as List<FoodOrderWeb.Models.FoodItem>;
}

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Thực đơn</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Hình ảnh món ăn -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow">
                <img src="@(Model.ImageUrl ?? "https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=80")"
                     class="card-img-top" alt="@Model.Name"
                     style="height: 400px; object-fit: cover;">
            </div>
        </div>

        <!-- Thông tin món ăn -->
        <div class="col-md-6">
            <div class="card border-0 shadow p-4">
                <h1 class="mb-3">@Model.Name</h1>

                <div class="mb-3">
                    <span class="badge bg-primary p-2">@Model.Category?.Name</span>
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success p-2 ms-2">Còn hàng</span>
                    }
                    else
                    {
                        <span class="badge bg-danger p-2 ms-2">Hết hàng</span>
                    }
                </div>

                <h3 class="text-primary mb-4">@Model.Price.ToString("#,0")đ</h3>

                <div class="mb-4">
                    <h5>Mô tả món ăn:</h5>
                    <p class="text-muted">@Model.Description</p>
                </div>

                <div class="mb-4">
                    <h5>Thông tin thêm:</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-clock text-primary me-2"></i>
                            Thời gian chuẩn bị: 15-20 phút
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-fire text-primary me-2"></i>
                            Calo: 350-450 kcal
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-users text-primary me-2"></i>
                            Phù hợp: 1-2 người
                        </li>
                    </ul>
                </div>

                <!-- Call to action cho Guest -->
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    Vui lòng <a asp-controller="Account" asp-action="Login" class="alert-link">đăng nhập</a>
                    hoặc <a asp-controller="Account" asp-action="Register" class="alert-link">đăng ký</a>
                    để đặt món ăn này.
                </div>

                <div class="d-flex gap-3">
                    <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary flex-grow-1">
                        <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Món ăn liên quan -->
    @if (relatedItems != null && relatedItems.Any())
    {
        <div class="row mt-5">
            <div class="col-12">
                <h3 class="mb-4">Có thể bạn cũng thích</h3>
                <div class="row g-4">
                    @foreach (var item in relatedItems)
                    {
                        <div class="col-md-3">
                            <div class="card h-100 border-0 shadow-sm hover-card">
                                <img src="@(item.ImageUrl ?? "https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?ixlib=rb-1.2.1&auto=format&fit=crop&w=300&q=80")"
                                     class="card-img-top" alt="@item.Name"
                                     style="height: 150px; object-fit: cover;">
                                <div class="card-body">
                                    <h6 class="card-title">@item.Name</h6>
                                    <p class="text-primary fw-bold mb-2">@item.Price.ToString("#,0")đ</p>
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary btn-sm w-100">
                                        Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2) !important;
        }
</style>