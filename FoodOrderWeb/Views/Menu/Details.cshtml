@model FoodOrderWeb.Models.FoodItem

@{
    ViewData["Title"] = Model.Name;
    var relatedItems = ViewBag.RelatedItems as List<FoodOrderWeb.Models.FoodItem>;
}

<!-- Breadcrumb -->
<section class="bg-light py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                        <i class="fas fa-home me-1"></i>Trang chủ
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-action="Index" class="text-decoration-none">
                        <i class="fas fa-list me-1"></i>Thực đơn
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Product Details -->
<section class="py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Product Images -->
            <div class="col-lg-6">
                <div class="position-relative">
                    <img src="@(Model.ImageUrl ?? "https://images.unsplash.com/photo-1546069901-ba9596a5e864?ixlib=rb-4.0.3&auto=format&fit=crop&w=1160&q=80")"
                         class="img-fluid rounded-4 shadow" alt="@Model.Name" id="mainImage"
                         style="width: 100%; height: 400px; object-fit: cover;">

                    @if (!Model.IsAvailable)
                    {
                        <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 rounded-4 d-flex align-items-center justify-content-center">
                            <span class="badge bg-danger fs-3 p-3">Hết hàng</span>
                        </div>
                    }

                    <!-- Badge danh mục -->
                    <span class="position-absolute top-0 start-0 bg-primary text-white px-3 py-2 m-3 rounded-pill">
                        <i class="fas fa-tag me-1"></i>@Model.Category?.Name
                    </span>
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-lg-6">
                <div class="mb-4">
                    <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>

                    <!-- Rating -->
                    <div class="d-flex align-items-center mb-3">
                        <div class="text-warning me-3">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star-half-alt"></i>
                            <span class="text-muted ms-2">(4.5)</span>
                        </div>
                        <span class="text-muted">| Đã bán: 1.2k+</span>
                    </div>

                    <!-- Price -->
                    <h2 class="text-primary fw-bold mb-4">@Model.Price.ToString("#,0")đ</h2>

                    <!-- Description -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">
                            <i class="fas fa-align-left me-2 text-primary"></i>
                            Mô tả:
                        </h5>
                        <p class="text-muted">@Model.Description</p>
                    </div>

                    <!-- Additional Info -->
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">
                            <i class="fas fa-info-circle me-2 text-primary"></i>
                            Thông tin thêm:
                        </h5>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                Nguyên liệu tươi ngon
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                Chế biến sạch sẽ
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                Đóng gói cẩn thận
                            </li>
                        </ul>
                    </div>

                    <!-- Add to Cart Section -->
                    @if (Model.IsAvailable)
                    {
                        @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                        {
                            <div class="card bg-light border-0 p-4 mb-4">
                                <h5 class="fw-bold mb-3">
                                    <i class="fas fa-shopping-cart me-2 text-primary"></i>
                                    Số lượng:
                                </h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="input-group">
                                            <button class="btn btn-outline-secondary" type="button" id="btnMinus">
                                                <i class="fas fa-minus"></i>
                                            </button>
                                            <input type="number" id="quantity" class="form-control text-center"
                                                   value="1" min="1" max="10" readonly>
                                            <button class="btn btn-outline-secondary" type="button" id="btnPlus">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <button class="btn btn-primary w-100 py-2" onclick="addToCart(@Model.Id)"
                                                id="btnAddToCart">
                                            <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                                        </button>
                                    </div>
                                </div>
                                <p class="text-muted small mt-2">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Còn hàng, số lượng tối đa 10
                                </p>
                            </div>
                        }
                        else if (!User.Identity.IsAuthenticated)
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Vui lòng <a asp-controller="Account" asp-action="Login" class="alert-link">đăng nhập</a>
                                để đặt món.
                            </div>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                Admin không thể đặt món. Vui lòng đăng nhập bằng tài khoản User.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-times-circle me-2"></i>
                            Món ăn này hiện đang hết hàng.
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="d-flex gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>

                        @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                        {
                            <button class="btn btn-outline-primary" onclick="addToWishlist(@Model.Id)">
                                <i class="far fa-heart"></i>
                            </button>
                            <button class="btn btn-outline-primary" onclick="shareProduct(@Model.Id)">
                                <i class="fas fa-share-alt"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Related Items -->
@if (relatedItems != null && relatedItems.Any())
{
    <section class="py-5 bg-light">
        <div class="container">
            <h3 class="fw-bold mb-4">
                <i class="fas fa-utensils me-2 text-primary"></i>
                Món ăn liên quan
            </h3>
            <div class="row g-4">
                @foreach (var related in relatedItems)
                {
                    <div class="col-lg-3 col-md-4 col-6">
                        <div class="card food-card h-100 border-0 shadow-sm">
                            <img src="@(related.ImageUrl ?? "https://images.unsplash.com/photo-1546069901-ba9596a5e864?ixlib=rb-4.0.3&auto=format&fit=crop&w=1160&q=80")"
                                 class="card-img-top" alt="@related.Name"
                                 style="height: 150px; object-fit: cover;">
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold mb-1">@related.Name</h6>
                                <p class="text-primary fw-bold mb-2">@related.Price.ToString("#,0")đ</p>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@related.Id"
                                       class="btn btn-outline-primary btn-sm flex-grow-1">
                                        <i class="fas fa-eye me-1"></i>Xem
                                    </a>
                                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin") && related.IsAvailable)
                                    {
                                        <button onclick="addToCart(@related.Id)"
                                                class="btn btn-primary btn-sm">
                                            <i class="fas fa-cart-plus"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Reviews Section -->
<section class="py-5">
    <div class="container">
        <h3 class="fw-bold mb-4">
            <i class="fas fa-star me-2 text-warning"></i>
            Đánh giá từ khách hàng
        </h3>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card bg-light border-0 p-4 text-center">
                    <h4 class="display-4 fw-bold text-primary">4.5</h4>
                    <div class="text-warning mb-2">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star-half-alt"></i>
                    </div>
                    <p class="text-muted mb-0">128 đánh giá</p>
                </div>
            </div>

            <div class="col-md-8">
                <!-- Review Item 1 -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <img src="https://randomuser.me/api/portraits/men/1.jpg"
                                 class="rounded-circle me-2" width="40" height="40" alt="user">
                            <div>
                                <h6 class="fw-bold mb-0">Nguyễn Văn A</h6>
                                <small class="text-muted">2 giờ trước</small>
                            </div>
                            <div class="ms-auto text-warning">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                            </div>
                        </div>
                        <p class="mb-0">Món ăn rất ngon, giao hàng nhanh. Sẽ ủng hộ tiếp!</p>
                    </div>
                </div>

                <!-- Review Item 2 -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <img src="https://randomuser.me/api/portraits/women/2.jpg"
                                 class="rounded-circle me-2" width="40" height="40" alt="user">
                            <div>
                                <h6 class="fw-bold mb-0">Trần Thị B</h6>
                                <small class="text-muted">5 giờ trước</small>
                            </div>
                            <div class="ms-auto text-warning">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star-half-alt"></i>
                            </div>
                        </div>
                        <p class="mb-0">Giá cả hợp lý, chất lượng tốt. Đóng gói cẩn thận.</p>
                    </div>
                </div>

                @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                {
                    <button class="btn btn-outline-primary w-100 mt-3">
                        <i class="fas fa-pen me-2"></i>Viết đánh giá
                    </button>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tăng giảm số lượng
            $('#btnPlus').click(function() {
                var quantity = parseInt($('#quantity').val());
                if (quantity < 10) {
                    $('#quantity').val(quantity + 1);
                }
            });

            $('#btnMinus').click(function() {
                var quantity = parseInt($('#quantity').val());
                if (quantity > 1) {
                    $('#quantity').val(quantity - 1);
                }
            });
        });

        // Hàm thêm vào giỏ hàng - ĐÃ SỬA LỖI
        function addToCart(foodItemId) {
            var quantity = $('#quantity').val();

            // Kiểm tra đăng nhập
            @if (!User.Identity.IsAuthenticated)
            {
                    <text>
                    alert('Vui lòng đăng nhập để thêm vào giỏ hàng');
                    window.location.href = '/Account/Login';
                    return;
                    </text>
            }

            // Kiểm tra role Admin
            @if (User.IsInRole("Admin"))
            {
                    <text>
                    alert('Admin không thể thêm vào giỏ hàng');
                    return;
                    </text>
            }

            // Disable button
            $('#btnAddToCart').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...');

            // Lấy anti-forgery token
            var token = $('input[name="__RequestVerificationToken"]').val();
            if (!token) {
                token = $('input[name="__RequestVerificationToken"]').val() ||
                        $('input[name="__RequestVerificationToken"]').val();
            }

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: {
                    foodItemId: foodItemId,
                    quantity: quantity,
                    __RequestVerificationToken: token
                },
                success: function(response) {
                    if (response.success) {
                        // Cập nhật số lượng giỏ hàng
                        $('#cartCount').text(response.cartCount).show();

                        // Hiển thị thông báo
                        if (typeof showToast === 'function') {
                            showToast('Đã thêm vào giỏ hàng!', 'success');
                        } else {
                            alert('Đã thêm vào giỏ hàng!');
                        }
                    } else {
                        if (typeof showToast === 'function') {
                            showToast(response.message || 'Có lỗi xảy ra!', 'error');
                        } else {
                            alert(response.message || 'Có lỗi xảy ra!');
                        }
                    }
                },
                error: function(xhr, status, error) {
                    console.error('AJAX Error:', xhr.responseText);

                    if (xhr.status === 401) {
                        alert('Phiên đăng nhập hết hạn. Vui lòng đăng nhập lại.');
                        window.location.href = '/Account/Login';
                    } else if (xhr.status === 400) {
                        alert('Yêu cầu không hợp lệ. Vui lòng tải lại trang.');
                        location.reload();
                    } else {
                        if (typeof showToast === 'function') {
                            showToast('Không thể kết nối đến server!', 'error');
                        } else {
                            alert('Không thể kết nối đến server!');
                        }
                    }
                },
                complete: function() {
                    $('#btnAddToCart').prop('disabled', false).html('<i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng');
                }
            });
        }

        // Hàm thêm vào wishlist
        function addToWishlist(foodItemId) {
            if (typeof showToast === 'function') {
                showToast('Đã thêm vào danh sách yêu thích', 'success');
            } else {
                alert('Đã thêm vào danh sách yêu thích');
            }
        }

        // Hàm chia sẻ
        function shareProduct(foodItemId) {
            // Copy link sản phẩm
            var url = window.location.href;
            navigator.clipboard.writeText(url).then(function() {
                if (typeof showToast === 'function') {
                    showToast('Đã copy link sản phẩm', 'info');
                } else {
                    alert('Đã copy link sản phẩm');
                }
            });
        }
    </script>
}

<style>
    .food-card {
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
    }

        .food-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
        }

        .food-card img {
            transition: transform 0.5s;
        }

        .food-card:hover img {
            transform: scale(1.1);
        }

    @@media (max-width: 768px) {
        .display-5 {
            font-size: 2rem;
        }

        .btn {
            font-size: 0.9rem;
        }
    }
</style>