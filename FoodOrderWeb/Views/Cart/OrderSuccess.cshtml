@model FoodOrderWeb.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<!-- Breadcrumb -->
<section class="bg-light py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                <li class="breadcrumb-item active">Đặt hàng thành công</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <!-- Success Message -->
                <div class="card border-0 shadow-lg text-center">
                    <div class="card-body p-5">
                        <div class="mb-4">
                            <div class="success-animation">
                                <i class="fas fa-check-circle text-success fa-5f"></i>
                            </div>
                        </div>

                        <h2 class="fw-bold mb-3">Đặt hàng thành công!</h2>

                        <p class="lead text-muted mb-4">
                            Cảm ơn bạn đã đặt hàng. Đơn hàng của bạn đã được ghi nhận.
                        </p>

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success mb-4">
                                <i class="fas fa-check-circle me-2"></i>
                                @TempData["SuccessMessage"]
                            </div>
                        }

                        <!-- Order Info Card -->
                        <div class="card bg-light border-0 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3">Thông tin đơn hàng #@Model.Id</h5>

                                <div class="row text-start">
                                    <div class="col-md-6">
                                        <p class="mb-2">
                                            <i class="far fa-calendar-alt text-primary me-2"></i>
                                            <strong>Ngày đặt:</strong>
                                            @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-tag text-primary me-2"></i>
                                            <strong>Tổng tiền:</strong>
                                            <span class="text-primary fw-bold">@Model.TotalAmount.ToString("#,0")đ</span>
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-credit-card text-primary me-2"></i>
                                            <strong>Thanh toán:</strong>
                                            @if (Model.PaymentMethod == PaymentMethod.Cash)
                                            {
                                                <span>Tiền mặt</span>
                                            }
                                            else
                                            {
                                                <span>Ví điện tử</span>
                                            }
                                        </p>
                                    </div>

                                    <div class="col-md-6">
                                        <p class="mb-2">
                                            <i class="fas fa-user text-primary me-2"></i>
                                            <strong>Người nhận:</strong> @Model.ReceiverName
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-phone text-primary me-2"></i>
                                            <strong>SĐT:</strong> @Model.PhoneNumber
                                        </p>
                                        <p class="mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <strong>Địa chỉ:</strong> @Model.ShippingAddress
                                        </p>
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <strong>Trạng thái:</strong>
                                    @switch (Model.Status)
                                    {
                                        case OrderStatus.Pending:
                                            <span class="badge bg-warning ms-2">Chờ xác nhận</span>
                                            break;
                                        case OrderStatus.Confirmed:
                                            <span class="badge bg-info ms-2">Đã xác nhận</span>
                                            break;
                                        case OrderStatus.Preparing:
                                            <span class="badge bg-primary ms-2">Đang chuẩn bị</span>
                                            break;
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Order Details -->
                        <div class="card border-0 mb-4">
                            <div class="card-header bg-white py-3">
                                <h5 class="mb-0 fw-bold">Chi tiết đơn hàng</h5>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="bg-light">
                                            <tr>
                                                <th>Món ăn</th>
                                                <th class="text-center">Số lượng</th>
                                                <th class="text-end">Đơn giá</th>
                                                <th class="text-end">Thành tiền</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.OrderItems)
                                            {
                                                <tr>
                                                    <td>@item.FoodItem.Name</td>
                                                    <td class="text-center">@item.Quantity</td>
                                                    <td class="text-end">@item.Price.ToString("#,0")đ</td>
                                                    <td class="text-end fw-bold">
                                                        @((item.Quantity * item.Price).ToString("#,0"))đ
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-3 justify-content-center">
                            <a asp-controller="Order" asp-action="Details" asp-route-id="@Model.Id"
                               class="btn btn-outline-primary btn-lg px-4">
                                <i class="fas fa-eye me-2"></i>Xem chi tiết
                            </a>
                            <a asp-controller="Menu" asp-action="Index" class="btn btn-primary btn-lg px-4">
                                <i class="fas fa-utensils me-2"></i>Tiếp tục mua sắm
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Delivery Progress -->
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Tiến trình giao hàng</h5>
                        <div class="progress-tracker">
                            <div class="progress-step @(Model.Status >= OrderStatus.Pending ? "completed" : "")">
                                <div class="step-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="step-label">Đặt hàng</div>
                            </div>
                            <div class="progress-step @(Model.Status >= OrderStatus.Confirmed ? "completed" : "")">
                                <div class="step-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="step-label">Xác nhận</div>
                            </div>
                            <div class="progress-step @(Model.Status >= OrderStatus.Preparing ? "completed" : "")">
                                <div class="step-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="step-label">Chuẩn bị</div>
                            </div>
                            <div class="progress-step @(Model.Status >= OrderStatus.Delivering ? "completed" : "")">
                                <div class="step-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="step-label">Giao hàng</div>
                            </div>
                            <div class="progress-step @(Model.Status >= OrderStatus.Delivered ? "completed" : "")">
                                <div class="step-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="step-label">Hoàn thành</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .success-animation i {
        font-size: 5rem;
        animation: scaleSuccess 0.5s ease;
    }

    @@keyframes scaleSuccess {
        0% {
            transform: scale(0);
        }

        50% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
        }
    }

    .progress-tracker {
        display: flex;
        justify-content: space-between;
        position: relative;
    }

        .progress-tracker::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 50px;
            right: 50px;
            height: 2px;
            background: #e0e0e0;
            z-index: 1;
        }

    .progress-step {
        text-align: center;
        position: relative;
        z-index: 2;
    }

        .progress-step.completed .step-icon {
            color: #28a745;
        }

        .progress-step .step-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: white;
            border: 2px solid #e0e0e0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 1.2rem;
            color: #999;
            transition: all 0.3s;
        }

        .progress-step.completed .step-icon {
            border-color: #28a745;
            background: #28a745;
            color: white;
        }

    .step-label {
        font-size: 0.9rem;
        color: #666;
    }

    .progress-step.completed .step-label {
        color: #28a745;
        font-weight: 500;
    }
</style>