@model IEnumerable<FoodOrderWeb.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="fas fa-clipboard-list me-2"></i>Đơn hàng của tôi
    </h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Chưa có đơn hàng nào</h4>
            <p class="mb-3">Hãy đặt hàng ngay để thưởng thức những món ăn ngon</p>
            <a asp-controller="Menu" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-utensils me-2"></i>Xem thực đơn
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Đơn hàng #@order.Id</h5>
                            @switch (order.Status)
                            {
                                case OrderStatus.Pending:
                                    <span class="badge bg-warning">Chờ xác nhận</span>
                                    break;
                                case OrderStatus.Confirmed:
                                    <span class="badge bg-info">Đã xác nhận</span>
                                    break;
                                case OrderStatus.Preparing:
                                    <span class="badge bg-primary">Đang chuẩn bị</span>
                                    break;
                                case OrderStatus.Delivering:
                                    <span class="badge bg-secondary">Đang giao</span>
                                    break;
                                case OrderStatus.Delivered:
                                    <span class="badge bg-success">Đã giao</span>
                                    break;
                                case OrderStatus.Cancelled:
                                    <span class="badge bg-danger">Đã hủy</span>
                                    break;
                            }
                        </div>
                        <div class="card-body">
                            <p class="mb-2">
                                <i class="far fa-calendar-alt me-2"></i>
                                @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </p>
                            <p class="mb-2">
                                <i class="fas fa-tag me-2"></i>
                                Tổng tiền: <span class="text-primary fw-bold">@order.TotalAmount.ToString("#,0")đ</span>
                            </p>
                            <p class="mb-2">
                                <i class="fas fa-credit-card me-2"></i>
                                Thanh toán:
                                @if (order.PaymentMethod == PaymentMethod.Cash)
                                {
                                    <span>Tiền mặt</span>
                                }
                                else
                                {
                                    <span>Ví điện tử</span>
                                }
                                @if (order.IsPaid)
                                {
                                    <span class="badge bg-success ms-2">Đã thanh toán</span>
                                }
                            </p>
                            <p class="mb-2">
                                <i class="fas fa-map-marker-alt me-2"></i>
                                @order.ShippingAddress
                            </p>
                            <p class="mb-0">
                                <strong>Số lượng món:</strong> @order.OrderItems?.Sum(oi => oi.Quantity) món
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-action="Details" asp-route-id="@order.Id"
                               class="btn btn-outline-primary">
                                <i class="fas fa-eye me-2"></i>Xem chi tiết
                            </a>

                            @if (order.Status == OrderStatus.Pending)
                            {
                                <button onclick="cancelOrder(@order.Id)"
                                        class="btn btn-outline-danger">
                                    <i class="fas fa-times-circle me-2"></i>Hủy đơn
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function cancelOrder(orderId) {
            if (confirm('Bạn có chắc muốn hủy đơn hàng này?')) {
                $.post('/Order/Cancel/' + orderId, {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }).done(function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                });
            }
        }
    </script>
}