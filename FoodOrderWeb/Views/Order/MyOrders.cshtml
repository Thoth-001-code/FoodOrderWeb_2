@model IEnumerable<FoodOrderWeb.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<!-- Breadcrumb -->
<section class="bg-light py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                        <i class="fas fa-home me-1"></i>Trang chủ
                    </a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    <i class="fas fa-clipboard-list me-1"></i>Đơn hàng của tôi
                </li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">
                            <i class="fas fa-filter me-2 text-primary"></i>
                            Bộ lọc
                        </h5>
                    </div>
                    <div class="list-group list-group-flush">
                        <a asp-action="MyOrders"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CurrentStatus == null ? "active" : "")">
                            Tất cả
                            <span class="badge bg-primary rounded-pill">@ViewBag.TotalOrders</span>
                        </a>
                        <a asp-action="MyOrders" asp-route-status="Pending"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CurrentStatus == "Pending" ? "active" : "")">
                            <span><i class="fas fa-clock text-warning me-2"></i>Chờ xác nhận</span>
                            <span class="badge bg-warning rounded-pill">@ViewBag.PendingCount</span>
                        </a>
                        <a asp-action="MyOrders" asp-route-status="Confirmed"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CurrentStatus == "Confirmed" ? "active" : "")">
                            <span><i class="fas fa-check-circle text-info me-2"></i>Đã xác nhận</span>
                            <span class="badge bg-info rounded-pill">@ViewBag.ConfirmedCount</span>
                        </a>
                        <a asp-action="MyOrders" asp-route-status="Preparing"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CurrentStatus == "Preparing" ? "active" : "")">
                            <span><i class="fas fa-utensils text-primary me-2"></i>Đang chuẩn bị</span>
                            <span class="badge bg-primary rounded-pill">@ViewBag.PreparingCount</span>
                        </a>
                        <a asp-action="MyOrders" asp-route-status="Delivering"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CurrentStatus == "Delivering" ? "active" : "")">
                            <span><i class="fas fa-truck text-secondary me-2"></i>Đang giao</span>
                            <span class="badge bg-secondary rounded-pill">@ViewBag.DeliveringCount</span>
                        </a>
                        <a asp-action="MyOrders" asp-route-status="Delivered"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CurrentStatus == "Delivered" ? "active" : "")">
                            <span><i class="fas fa-check-circle text-success me-2"></i>Đã giao</span>
                            <span class="badge bg-success rounded-pill">@ViewBag.DeliveredCount</span>
                        </a>
                        <a asp-action="MyOrders" asp-route-status="Cancelled"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CurrentStatus == "Cancelled" ? "active" : "")">
                            <span><i class="fas fa-times-circle text-danger me-2"></i>Đã hủy</span>
                            <span class="badge bg-danger rounded-pill">@ViewBag.CancelledCount</span>
                        </a>
                    </div>
                </div>

                <!-- Stats Card -->
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">
                            <i class="fas fa-chart-pie me-2 text-primary"></i>
                            Thống kê
                        </h6>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tổng đơn:</span>
                            <span class="fw-bold">@ViewBag.TotalOrders</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Đã giao:</span>
                            <span class="fw-bold text-success">@ViewBag.DeliveredCount</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Tổng chi:</span>
                            <span class="fw-bold text-primary">@ViewBag.TotalSpent.ToString("#,0")đ</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Orders List -->
            <div class="col-lg-9">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">
                            <i class="fas fa-clipboard-list me-2 text-primary"></i>
                            Danh sách đơn hàng
                            @if (!string.IsNullOrEmpty(ViewBag.CurrentStatus))
                            {
                                <span class="fs-6 text-muted ms-2">
                                    - @ViewBag.CurrentStatus
                                </span>
                            }
                        </h5>

                        @if (ViewBag.TotalPages > 1)
                        {
                            <div class="d-flex align-items-center">
                                <span class="text-muted small me-2">Trang @ViewBag.CurrentPage / @ViewBag.TotalPages</span>
                            </div>
                        }
                    </div>

                    <div class="card-body p-0">
                        @if (Model == null || !Model.Any())
                        {
                            <div class="text-center py-5">
                                <div class="mb-3">
                                    <i class="fas fa-box-open fa-4x text-muted"></i>
                                </div>
                                <h5 class="text-muted mb-3">Chưa có đơn hàng nào</h5>
                                <p class="text-muted mb-3">Hãy đặt hàng ngay để thưởng thức những món ăn ngon</p>
                                <a asp-controller="Menu" asp-action="Index" class="btn btn-primary">
                                    <i class="fas fa-utensils me-2"></i>Xem thực đơn
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="px-4">Mã ĐH</th>
                                            <th>Ngày đặt</th>
                                            <th>Món ăn</th>
                                            <th class="text-end">Tổng tiền</th>
                                            <th>Trạng thái</th>
                                            <th class="text-center">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var order in Model)
                                        {
                                            @if (order != null)
                                            {
                                                <tr>
                                                    <td class="px-4 fw-bold">#@order.Id</td>
                                                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td>
                                                        @{
                                                            var firstItem = order.OrderItems?.FirstOrDefault();
                                                            var itemCount = order.OrderItems?.Count() ?? 0;
                                                        }

                                                        @if (firstItem != null && firstItem.FoodItem != null)
                                                        {
                                                            <span>@firstItem.FoodItem.Name</span>
                                                            @if (itemCount > 1)
                                                            {
                                                                <span class="text-muted small ms-1">và @(itemCount - 1) món khác</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">Không có thông tin</span>
                                                        }
                                                    </td>
                                                    <td class="text-end fw-bold text-primary">
                                                        @order.TotalAmount.ToString("#,0")đ
                                                    </td>
                                                    <td>
                                                        @switch (order.Status)
                                                        {
                                                            case OrderStatus.Pending:
                                                                <span class="badge bg-warning">Chờ xác nhận</span>
                                                                break;
                                                            case OrderStatus.Confirmed:
                                                                <span class="badge bg-info">Đã xác nhận</span>
                                                                break;
                                                            case OrderStatus.Preparing:
                                                                <span class="badge bg-primary">Đang chuẩn bị</span>
                                                                break;
                                                            case OrderStatus.Delivering:
                                                                <span class="badge bg-secondary">Đang giao</span>
                                                                break;
                                                            case OrderStatus.Delivered:
                                                                <span class="badge bg-success">Đã giao</span>
                                                                break;
                                                            case OrderStatus.Cancelled:
                                                                <span class="badge bg-danger">Đã hủy</span>
                                                                break;
                                                            default:
                                                                <span class="badge bg-dark">Không xác định</span>
                                                                break;
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="btn-group" role="group">
                                                            <a asp-action="Details" asp-route-id="@order.Id"
                                                               class="btn btn-sm btn-outline-primary"
                                                               data-bs-toggle="tooltip" title="Xem chi tiết">
                                                                <i class="fas fa-eye"></i>
                                                            </a>
                                                            @if (order.Status == OrderStatus.Pending)
                                                            {
                                                                <button onclick="cancelOrder(@order.Id)"
                                                                        class="btn btn-sm btn-outline-danger"
                                                                        data-bs-toggle="tooltip" title="Hủy đơn">
                                                                    <i class="fas fa-times"></i>
                                                                </button>
                                                            }
                                                            @if (order.Status == OrderStatus.Delivered)
                                                            {
                                                                <a asp-action="Invoice" asp-route-id="@order.Id"
                                                                   class="btn btn-sm btn-outline-success"
                                                                   data-bs-toggle="tooltip" title="Xem hóa đơn">
                                                                    <i class="fas fa-file-invoice"></i>
                                                                </a>
                                                                <button onclick="reorder(@order.Id)"
                                                                        class="btn btn-sm btn-outline-info"
                                                                        data-bs-toggle="tooltip" title="Đặt lại">
                                                                    <i class="fas fa-redo"></i>
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pagination -->
                            @if (ViewBag.TotalPages > 1)
                            {
                                <div class="card-footer bg-white">
                                    <nav aria-label="Page navigation">
                                        <ul class="pagination justify-content-center mb-0">
                                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                                <a class="page-link" asp-action="MyOrders"
                                                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                                                   asp-route-status="@ViewBag.CurrentStatus">
                                                    <i class="fas fa-chevron-left"></i>
                                                </a>
                                            </li>

                                            @{
                                                int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                                int endPage = Math.Min(ViewBag.TotalPages, startPage + 4);
                                                if (endPage - startPage < 4)
                                                {
                                                    startPage = Math.Max(1, endPage - 4);
                                                }
                                            }

                                            @if (startPage > 1)
                                            {
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="MyOrders"
                                                       asp-route-page="1"
                                                       asp-route-status="@ViewBag.CurrentStatus">1</a>
                                                </li>
                                                @if (startPage > 2)
                                                {
                                                    <li class="page-item disabled">
                                                        <span class="page-link">...</span>
                                                    </li>
                                                }
                                            }

                                            @for (int i = startPage; i <= endPage; i++)
                                            {
                                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                                    <a class="page-link" asp-action="MyOrders"
                                                       asp-route-page="@i"
                                                       asp-route-status="@ViewBag.CurrentStatus">@i</a>
                                                </li>
                                            }

                                            @if (endPage < ViewBag.TotalPages)
                                            {
                                                @if (endPage < ViewBag.TotalPages - 1)
                                                {
                                                    <li class="page-item disabled">
                                                        <span class="page-link">...</span>
                                                    </li>
                                                }
                                                <li class="page-item">
                                                    <a class="page-link" asp-action="MyOrders"
                                                       asp-route-page="@ViewBag.TotalPages"
                                                       asp-route-status="@ViewBag.CurrentStatus">@ViewBag.TotalPages</a>
                                                </li>
                                            }

                                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                                <a class="page-link" asp-action="MyOrders"
                                                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                                                   asp-route-status="@ViewBag.CurrentStatus">
                                                    <i class="fas fa-chevron-right"></i>
                                                </a>
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });

        function cancelOrder(orderId) {
            if (confirm('Bạn có chắc muốn hủy đơn hàng này?')) {
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Order/Cancel/' + orderId,
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token
                    },
                    success: function(response) {
                        if (response.success) {
                            if (typeof showToast === 'function') {
                                showToast('Hủy đơn hàng thành công', 'success');
                            } else {
                                alert('Hủy đơn hàng thành công');
                            }
                            setTimeout(function() {
                                location.reload();
                            }, 1500);
                        } else {
                            if (typeof showToast === 'function') {
                                showToast(response.message || 'Có lỗi xảy ra', 'error');
                            } else {
                                alert(response.message || 'Có lỗi xảy ra');
                            }
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error:', error);
                        if (typeof showToast === 'function') {
                            showToast('Có lỗi xảy ra khi hủy đơn hàng', 'error');
                        } else {
                            alert('Có lỗi xảy ra khi hủy đơn hàng');
                        }
                    }
                });
            }
        }

        function reorder(orderId) {
            if (confirm('Thêm các món từ đơn hàng này vào giỏ?')) {
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Order/Reorder/' + orderId,
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token
                    },
                    success: function(response) {
                        if (response.success) {
                            if (typeof showToast === 'function') {
                                showToast('Đã thêm vào giỏ hàng', 'success');
                            } else {
                                alert('Đã thêm vào giỏ hàng');
                            }
                            setTimeout(function() {
                                window.location.href = '/Cart';
                            }, 1500);
                        } else {
                            if (typeof showToast === 'function') {
                                showToast(response.message || 'Có lỗi xảy ra', 'error');
                            } else {
                                alert(response.message || 'Có lỗi xảy ra');
                            }
                        }
                    },
                    error: function() {
                        if (typeof showToast === 'function') {
                            showToast('Có lỗi xảy ra khi thêm vào giỏ', 'error');
                        } else {
                            alert('Có lỗi xảy ra khi thêm vào giỏ');
                        }
                    }
                });
            }
        }
    </script>
}