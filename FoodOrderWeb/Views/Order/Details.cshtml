@model FoodOrderWeb.Models.Order

@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Id}";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="MyOrders">Đơn hàng của tôi</a></li>
            <li class="breadcrumb-item active">Chi tiết đơn hàng #@Model.Id</li>
        </ol>
    </nav>

    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Đơn hàng #@Model.Id</h4>
            @switch (Model.Status)
            {
                case OrderStatus.Pending:
                    <span class="badge bg-warning fs-6">Chờ xác nhận</span>
                    break;
                case OrderStatus.Confirmed:
                    <span class="badge bg-info fs-6">Đã xác nhận</span>
                    break;
                case OrderStatus.Preparing:
                    <span class="badge bg-primary fs-6">Đang chuẩn bị</span>
                    break;
                case OrderStatus.Delivering:
                    <span class="badge bg-secondary fs-6">Đang giao</span>
                    break;
                case OrderStatus.Delivered:
                    <span class="badge bg-success fs-6">Đã giao</span>
                    break;
                case OrderStatus.Cancelled:
                    <span class="badge bg-danger fs-6">Đã hủy</span>
                    break;
            }
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5>Thông tin đơn hàng</h5>
                    <table class="table table-borderless">
                        <tr>
                            <td><strong>Ngày đặt:</strong></td>
                            <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        </tr>
                        <tr>
                            <td><strong>Phương thức thanh toán:</strong></td>
                            <td>
                                @if (Model.PaymentMethod == PaymentMethod.Cash)
                                {
                                    <span>Tiền mặt</span>
                                }
                                else
                                {
                                    <span>Ví điện tử</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Trạng thái thanh toán:</strong></td>
                            <td>
                                @if (Model.IsPaid)
                                {
                                    <span class="badge bg-success">Đã thanh toán</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Chưa thanh toán</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>

                <div class="col-md-6">
                    <h5>Thông tin giao hàng</h5>
                    <table class="table table-borderless">
                        <tr>
                            <td><strong>Người nhận:</strong></td>
                            <td>@Model.ReceiverName</td>
                        </tr>
                        <tr>
                            <td><strong>Số điện thoại:</strong></td>
                            <td>@Model.PhoneNumber</td>
                        </tr>
                        <tr>
                            <td><strong>Địa chỉ:</strong></td>
                            <td>@Model.ShippingAddress</td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <tr>
                                <td><strong>Ghi chú:</strong></td>
                                <td>@Model.Notes</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>

            <h5>Chi tiết món ăn</h5>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Món ăn</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@item.FoodItem.Name</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.Price.ToString("#,0")đ</td>
                                <td class="text-end">@((item.Quantity * item.Price).ToString("#,0"))đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Tổng cộng:</th>
                            <th class="text-end text-primary">@Model.TotalAmount.ToString("#,0")đ</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-4">
                <a asp-action="MyOrders" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>

                @if (Model.Status == OrderStatus.Pending)
                {
                    <button onclick="cancelOrder(@Model.Id)" class="btn btn-danger">
                        <i class="fas fa-times-circle me-2"></i>Hủy đơn hàng
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function cancelOrder(orderId) {
            if (confirm('Bạn có chắc muốn hủy đơn hàng này?')) {
                $.post('/Order/Cancel/' + orderId, {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }).done(function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                });
            }
        }
    </script>
}