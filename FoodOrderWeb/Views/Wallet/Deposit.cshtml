@model FoodOrderWeb.ViewModels.DepositViewModel

@{
    ViewData["Title"] = "Nạp tiền vào ví";
}

<!-- Breadcrumb -->
<section class="bg-light py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Ví điện tử</a></li>
                <li class="breadcrumb-item active">Nạp tiền</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-success text-white py-3">
                        <h4 class="mb-0 fw-bold">
                            <i class="fas fa-plus-circle me-2"></i>
                            Nạp tiền vào ví
                        </h4>
                    </div>

                    <div class="card-body p-4">
                        <form asp-action="Deposit" method="post" id="depositForm">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <!-- Amount Input -->
                            <div class="mb-4">
                                <label asp-for="Amount" class="form-label fw-bold fs-5"></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light">
                                        <i class="fas fa-dollar-sign"></i>
                                    </span>
                                    <input asp-for="Amount" class="form-control text-end"
                                           type="number" min="10000" step="10000"
                                           placeholder="Nhập số tiền" id="amountInput" />
                                    <span class="input-group-text bg-light">đ</span>
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                                <div class="form-text">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Số tiền nạp từ 10,000đ đến 10,000,000đ
                                </div>
                            </div>

                            <!-- Quick Amounts -->
                            <div class="mb-4">
                                <label class="form-label fw-bold">Nạp nhanh</label>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var amount in Model.QuickAmounts)
                                    {
                                        <button type="button" class="btn btn-outline-primary quick-amount"
                                                data-amount="@amount">
                                            @amount.ToString("#,0")đ
                                        </button>
                                    }
                                </div>
                            </div>

                            <!-- Description -->
                            <div class="mb-4">
                                <label asp-for="Description" class="form-label fw-bold"></label>
                                <textarea asp-for="Description" class="form-control" rows="2"
                                          placeholder="Ghi chú (không bắt buộc)"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <!-- Payment Methods -->
                            <div class="mb-4">
                                <label class="form-label fw-bold">Phương thức thanh toán</label>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="payment-method border rounded-3 p-3 text-center">
                                            <input type="radio" name="paymentMethod" id="methodBank"
                                                   class="form-check-input" checked>
                                            <label for="methodBank" class="d-block">
                                                <i class="fas fa-university fa-2x text-primary mb-2"></i>
                                                <span class="fw-bold d-block">Chuyển khoản</span>
                                                <small class="text-muted">Qua ngân hàng</small>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="payment-method border rounded-3 p-3 text-center">
                                            <input type="radio" name="paymentMethod" id="methodCard"
                                                   class="form-check-input">
                                            <label for="methodCard" class="d-block">
                                                <i class="fas fa-credit-card fa-2x text-success mb-2"></i>
                                                <span class="fw-bold d-block">Thẻ ATM</span>
                                                <small class="text-muted">Nội địa</small>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Bank Info (for demo) -->
                            <div class="alert alert-info bank-info mb-4">
                                <h6 class="fw-bold mb-2">
                                    <i class="fas fa-university me-2"></i>
                                    Thông tin chuyển khoản (Demo)
                                </h6>
                                <p class="small mb-1">
                                    <strong>Ngân hàng:</strong> Vietcombank
                                </p>
                                <p class="small mb-1">
                                    <strong>Số tài khoản:</strong> 1234567890
                                </p>
                                <p class="small mb-1">
                                    <strong>Chủ tài khoản:</strong> FOODORDER COMPANY
                                </p>
                                <p class="small mb-0">
                                    <strong>Nội dung:</strong> NAP <span id="displayAmount">[SỐ TIỀN]</span>
                                </p>
                            </div>

                            <!-- Note -->
                            <div class="alert alert-warning mb-4">
                                <i class="fas fa-shield-alt me-2"></i>
                                <strong>Lưu ý:</strong> Đây là chức năng nạp tiền giả lập.
                                Số tiền sẽ được cộng ngay vào ví để bạn trải nghiệm.
                            </div>

                            <!-- Actions -->
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-check-circle me-2"></i>Xác nhận nạp tiền
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Features -->
                <div class="row g-3 mt-4">
                    <div class="col-4">
                        <div class="text-center">
                            <i class="fas fa-bolt fa-2x text-primary mb-2"></i>
                            <h6 class="fw-bold mb-1">Nạp nhanh</h6>
                            <small class="text-muted">Cộng tiền tức thì</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-center">
                            <i class="fas fa-shield-alt fa-2x text-success mb-2"></i>
                            <h6 class="fw-bold mb-1">Bảo mật</h6>
                            <small class="text-muted">An toàn tuyệt đối</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-center">
                            <i class="fas fa-gift fa-2x text-warning mb-2"></i>
                            <h6 class="fw-bold mb-1">Ưu đãi</h6>
                            <small class="text-muted">Nhiều ưu đãi hấp dẫn</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Quick amount buttons
            $('.quick-amount').click(function() {
                var amount = $(this).data('amount');
                $('#amountInput').val(amount).trigger('input');
            });

            // Update display amount
            $('#amountInput').on('input', function() {
                var amount = $(this).val();
                if (amount) {
                    $('#displayAmount').text(parseInt(amount).toLocaleString('vi-VN'));
                } else {
                    $('#displayAmount').text('[SỐ TIỀN]');
                }
            });

            // Payment method switch
            $('input[name="paymentMethod"]').change(function() {
                if ($(this).val() === 'bank') {
                    $('.bank-info').show();
                } else {
                    $('.bank-info').hide();
                }
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .payment-method {
        cursor: pointer;
        transition: all 0.3s;
    }

        .payment-method:hover {
            border-color: var(--primary-color) !important;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .payment-method input[type="radio"] {
            display: none;
        }

            .payment-method input[type="radio"]:checked + label {
                color: var(--primary-color);
            }

    .quick-amount {
        min-width: 100px;
    }
</style>